<Window x:Class="Cadeaubons_Presentation.Windows.AddEditThemeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cadeaubons_Presentation.Windows"
        mc:Ignorable="d"
        Title="Thema" Height="500" Width="500"
        Background="White"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="350"
                        Margin="0,20">

                <TextBlock Text="🎨"
                           FontSize="36"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,5"/>

                <TextBlock x:Name="TxtTitle"
                           Text="Nieuw thema toevoegen"
                           Style="{StaticResource WindowTitle}"
                           Margin="0,0,0,20"/>

                <!-- Name -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="🏷" FontSize="14" Margin="0,0,6,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Naam *"
                               Style="{StaticResource FieldLabel}"/>
                </StackPanel>
                <TextBox x:Name="TxtName"
                         Style="{StaticResource RoundedTextBox}"
                         Margin="0,0,0,10"/>

                <!-- Description -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="📝" FontSize="14" Margin="0,0,6,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Omschrijving"
                               Style="{StaticResource FieldLabel}"/>
                </StackPanel>
                <TextBox x:Name="TxtDescription"
                         Style="{StaticResource RoundedTextBox}"
                         Height="70"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalContentAlignment="Top"
                         Margin="0,0,0,10"/>

                <!-- Icon -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="🖼" FontSize="14" Margin="0,0,6,0"
               VerticalAlignment="Center"/>
                    <TextBlock Text="Icoon *"
               Style="{StaticResource FieldLabel}"/>
                </StackPanel>

                <!-- Emoji Palette Grid -->
                <Border BorderBrush="#CCCCCC"
        BorderThickness="1"
        CornerRadius="8"
        Padding="8"
        Margin="0,0,0,5">
                    <ItemsControl x:Name="EmojiPalette">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="36" Height="36"
                        Margin="2"
                        CornerRadius="6"
                        Background="Transparent"
                        Cursor="Hand"
                        MouseLeftButtonDown="Emoji_Click"
                        Tag="{Binding Emoji}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#E8E8E8"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Emoji}"
                               FontSize="20"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- Selected Emoji Preview -->
                <DockPanel Margin="0,0,0,20">
                    <Border Width="40" Height="40"
            CornerRadius="8"
            Background="#F5F5F5"
            DockPanel.Dock="Left"
            Margin="0,0,10,0">
                        <TextBlock x:Name="TxtSelectedEmoji"
                   Text="?"
                   FontSize="24"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="TxtSelectedEmojiLabel"
               Text="Geen icoon geselecteerd"
               Foreground="Gray"
               FontSize="13"
               VerticalAlignment="Center"/>
                </DockPanel>

                <!-- Primary Color -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="🎨" FontSize="14" Margin="0,0,6,0"
               VerticalAlignment="Center"/>
                    <TextBlock Text="Hoofdkleur *"
               Style="{StaticResource FieldLabel}"/>
                </StackPanel>

                <!-- Color Palette Grid -->
                <Border BorderBrush="#CCCCCC"
        BorderThickness="1"
        CornerRadius="8"
        Padding="8"
        Margin="0,0,0,5">
                    <ItemsControl x:Name="ColorPalette">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="28" Height="28"
                        Margin="2"
                        CornerRadius="4"
                        BorderBrush="#DDDDDD"
                        BorderThickness="1"
                        Background="{Binding Brush}"
                        Cursor="Hand"
                        MouseLeftButtonDown="Color_Click"
                        Tag="{Binding Hex}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- Selected Color Preview -->
                <DockPanel Margin="0,0,0,20">
                    <Border x:Name="ColorPreview"
            Width="30" Height="30"
            CornerRadius="6"
            Background="#EEEEEE"
            BorderBrush="#CCCCCC"
            BorderThickness="1"
            DockPanel.Dock="Left"
            Margin="0,0,10,0"/>
                    <TextBlock x:Name="TxtSelectedColor"
               Text="Geen kleur geselecteerd"
               Foreground="Gray"
               FontSize="13"
               VerticalAlignment="Center"/>
                </DockPanel>

                <!-- Save Button -->
                <Button x:Name="BtnSave"
                        Content="Thema opslaan"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,0,12"
                        Click="BtnSave_Click"/>

                <!-- Cancel Button -->
                <Button Content="Annuleren"
                        Style="{StaticResource SecondaryButton}"
                        Click="BtnCancel_Click"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>