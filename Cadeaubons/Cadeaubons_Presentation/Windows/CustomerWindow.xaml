<Window x:Class="Cadeaubons_Presentation.Windows.CustomerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cadeaubons_Presentation.Windows"
        mc:Ignorable="d"
        Title="CustomerWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="10">

            <Button Content="Log out"
            Style="{StaticResource DangerButton}"
            DockPanel.Dock="Right"
            Click="BtnLogout_Click"/>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <TextBlock Text="🎁"
                   FontSize="28"
                   Margin="0,0,10,0"/>

                <TextBlock x:Name="TxtWelcome"
                   Style="{StaticResource WindowTitle}"
                   VerticalAlignment="Center"/>

            </StackPanel>

        </DockPanel>

        <StackPanel Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="300">

            <Button Content="View All Themes"
                Style="{StaticResource PrimaryButton}"
                    Margin="0,0,0,10"
                Click="BtnViewThemes_Click"/>

            <Button Content="My Orders"
                            x:Name="BtnMyOrders"
                Style="{StaticResource PrimaryButton}"
                    Margin="0,0,0,10"
                            Click="BtnMyOrders_Click"/>
            
            
            

            <Button Content="Profile"
                Style="{StaticResource PrimaryButton}"
                    Margin="0,0,0,10"/>

        </StackPanel>
        <Button x:Name="PurchaseButton" Content="Purchase GiftCard" HorizontalAlignment="Center" Margin="0,312,0,0" Grid.Row="1" VerticalAlignment="Top" Width="300" Click="PurchaseButton_Click" Style="{StaticResource PrimaryButton}"/>

    </Grid>
</Window>
