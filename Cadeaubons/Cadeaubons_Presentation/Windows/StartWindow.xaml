<Window x:Class="Cadeaubons_Presentation.Windows.StartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cadeaubons_Presentation.Windows"
        mc:Ignorable="d"
        Title="Gift Voucher Platform"
        Height="550"
        Width="800"
        MinHeight="450"
        MinWidth="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="White">
    <Grid>


        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="350">
            <TextBlock Text="🎁"
                           FontSize="36"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,5"/>

                <TextBlock Text="Welcome"
                           Style="{StaticResource WindowTitle}"
                           Margin="0,0,0,5"/>

                <TextBlock Text="Log in to your account or register as a new user."
                           FontSize="14"
                           Foreground="Gray"
                           TextAlignment="Center"
                           Margin="0,0,0,25"/>

                <!-- Email -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="✉" FontSize="14" Margin="0,0,6,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Email" Style="{StaticResource FieldLabel}"/>
                </StackPanel>
                <TextBox x:Name="TxtEmail"
                         Style="{StaticResource RoundedTextBox}"
                         Margin="0,0,0,15"/>

                <!-- Password -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="🔒" FontSize="14" Margin="0,0,6,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Password" Style="{StaticResource FieldLabel}"/>
                </StackPanel>
                <PasswordBox x:Name="PwdPassword"
                             Style="{StaticResource RoundedPasswordBox}"
                             Margin="0,0,0,25"/>

                <Button x:Name="BtnLogin"
                        Content="Login"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,0,12"
                        Click="BtnLogin_Click"/>

                <Button x:Name="BtnRegister"
                        Content="Register as new user"
                        Style="{StaticResource SecondaryButton}"
                        Click="BtnRegister_Click"/>
            </StackPanel>
        
    </Grid>
</Window>