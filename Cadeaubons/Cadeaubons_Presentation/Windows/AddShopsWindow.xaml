<Window x:Class="Cadeaubons_Presentation.Windows.AddShopsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cadeaubons_Presentation.Windows"
        mc:Ignorable="d"
        Title="AddShopsWindow" Height="450" Width="800">
    <Grid>
        <TextBox x:Name="StoreNameTextBox" HorizontalAlignment="Left" Margin="262,71,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="239" Style="{StaticResource RoundedTextBox}" Height="25"/>
        <TextBlock HorizontalAlignment="Left" Margin="262,35,0,0" TextWrapping="Wrap" Text="Store Name" VerticalAlignment="Top" Height="22" Width="239" Style="{StaticResource FieldLabel}"/>
        <TextBlock HorizontalAlignment="Left" Margin="262,130,0,0" TextWrapping="Wrap" Text="Store Adress" VerticalAlignment="Top" Width="239" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="StoreAdressTextBox" HorizontalAlignment="Left" Margin="262,161,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="239" Style="{StaticResource RoundedTextBox}" Height="24"/>
        <TextBlock HorizontalAlignment="Left" Margin="262,203,0,0" TextWrapping="Wrap" Text="Store Number" VerticalAlignment="Top" Width="120" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="StoreNumberTextBox" HorizontalAlignment="Left" Margin="262,234,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="239" Style="{StaticResource RoundedTextBox}" Height="22"/>
        <ComboBox x:Name="CitiesListComboBox" HorizontalAlignment="Left" Margin="262,304,0,0" VerticalAlignment="Top" Width="239"/>
        <Button Content="Add Shop" HorizontalAlignment="Left" Margin="262,355,0,0" VerticalAlignment="Top" Width="120" Click="Button_Click"  Style="{StaticResource PrimaryButton}"/>
        <TextBlock HorizontalAlignment="Left" Margin="262,270,0,0" TextWrapping="Wrap" Text="City" VerticalAlignment="Top" RenderTransformOrigin="2.678,1.506" Width="120" Style="{StaticResource FieldLabel}"/>

    </Grid>
</Window>
