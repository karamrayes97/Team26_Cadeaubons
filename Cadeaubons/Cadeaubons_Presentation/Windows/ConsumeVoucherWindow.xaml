<Window x:Class="Cadeaubons_Presentation.Windows.ConsumeVoucherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cadeaubons_Presentation.Windows"
        mc:Ignorable="d"
        Title="ConsumeVoucherWindow" Height="450" Width="800">
    <Grid>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="320">

            <!-- Icon -->
            <TextBlock Text="💳"
                       FontSize="36"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,5"/>

            <!-- Title -->
            <TextBlock Text="Redeem Voucher"
                       Style="{StaticResource WindowTitle}"
                       Margin="0,0,0,5"/>

            <!-- Balance info -->
            <TextBlock x:Name="TxtBalance"
                       FontSize="13"
                       Foreground="Gray"
                       TextAlignment="Center"
                       Margin="0,0,0,15"/>

            <TextBlock Text="Amount *"
                       Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="TxtAmount"
                     Style="{StaticResource RoundedTextBox}"
                     Margin="0,0,0,10"/>

            <TextBlock Text="Reason *"
                       Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="TxtReason"
                     Style="{StaticResource RoundedTextBox}"
                     Margin="0,0,0,20"/>

            <TextBlock Text="Store *"
                       Style="{StaticResource FieldLabel}"/>
            <ComboBox x:Name="CbStores"
                      Height="38"
                      Margin="0,0,0,10"/>

            <Button x:Name="BtnConfirm"
                    Content="Confirm"
                    Style="{StaticResource PrimaryButton}"
                    Margin="0,0,0,10"
                    Click="BtnConfirm_Click"/>

            <Button Content="Cancel"
                    Style="{StaticResource SecondaryButton}"
                    Click="BtnCancel_Click"/>

        </StackPanel>
    </Grid>
</Window>
