<Window x:Class="Cadeaubons_Presentation.Windows.ConsumeVoucherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cadeaubons_Presentation.Windows"
        mc:Ignorable="d"
        Title="Bon gebruiken" Height="450" Width="800"
        Background="White"
WindowStartupLocation="CenterScreen">
    <Grid>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="320">

            <!-- Icon -->
            <TextBlock Text="💳"
                       FontSize="36"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,5"/>

            <!-- Title -->
            <TextBlock Text="Cadeaubon inwisselen"
                       Style="{StaticResource WindowTitle}"
                       Margin="0,0,0,5"/>

            <!-- Balance info -->
            <TextBlock x:Name="TxtBalance"
                       FontSize="13"
                       Foreground="Gray"
                       TextAlignment="Center"
                       Margin="0,0,0,15"/>

            <!-- Bedrag -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <TextBlock Text="💶" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                <TextBlock Text="Bedrag *" Style="{StaticResource FieldLabel}"/>
            </StackPanel>
            <TextBox x:Name="TxtAmount"
         Style="{StaticResource RoundedTextBox}"
         Margin="0,0,0,10"/>

            <!-- Reden -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <TextBlock Text="📝" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                <TextBlock Text="Reden *" Style="{StaticResource FieldLabel}"/>
            </StackPanel>
            <TextBox x:Name="TxtReason"
         Style="{StaticResource RoundedTextBox}"
         Margin="0,0,0,20"/>

            <!-- Winkel -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <TextBlock Text="🏪" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                <TextBlock Text="Winkel *" Style="{StaticResource FieldLabel}"/>
            </StackPanel>
            <ComboBox x:Name="CbStores"
          Height="38"
          Margin="0,0,0,10"/>

            <Button x:Name="BtnConfirm"
                    Content="Bevestigen"
                    Style="{StaticResource PrimaryButton}"
                    Margin="0,0,0,10"
                    Click="BtnConfirm_Click"/>

            <Button Content="Annuleren"
                    Style="{StaticResource SecondaryButton}"
                    Click="BtnCancel_Click"/>

        </StackPanel>
    </Grid>
</Window>