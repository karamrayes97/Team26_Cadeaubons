<Window x:Class="Cadeaubons_Presentation.Windows.ManageThemesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cadeaubons_Presentation.Windows"
        mc:Ignorable="d"
        Title="Manage Themes" Height="550" Width="800"
        Background="White"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="10">
            <Button Content="← Back"
                    Style="{StaticResource SecondaryButton}"
                    DockPanel.Dock="Right"
                    Width="100"
                    Click="BtnBack_Click"/>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🎨" FontSize="28" Margin="0,0,10,0"/>
                <TextBlock Text="Manage Themes"
                           Style="{StaticResource WindowTitle}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </DockPanel>

        <!-- Theme List -->
        <ListBox x:Name="ThemeList"
                 Grid.Row="1"
                 Margin="20,10"
                 BorderThickness="0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="#F5F5F5"
                            CornerRadius="8"
                            Padding="15,10"
                            Margin="0,0,0,5">
                        <DockPanel>
                            <!-- Delete button right -->
                            <Button Content="🗑"
                                    DockPanel.Dock="Right"
                                    Width="35" Height="35"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    FontSize="16"
                                    Cursor="Hand"
                                    Tag="{Binding Id}"
                                    Click="BtnDelete_Click"/>

                            <!-- Edit button right -->
                            <Button Content="✏"
                                    DockPanel.Dock="Right"
                                    Width="35" Height="35"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    FontSize="16"
                                    Cursor="Hand"
                                    Tag="{Binding Id}"
                                    Click="BtnEdit_Click"/>

                            <!-- Color preview -->
                            <Border Width="20" Height="20"
                                    CornerRadius="4"
                                    Margin="0,0,10,0"
                                    DockPanel.Dock="Left">
                                <Border.Background>
                                    <SolidColorBrush Color="{Binding PrimaryColor}"/>
                                </Border.Background>
                            </Border>

                            <!-- Name + Description -->
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="Bold"
                                           FontSize="14"/>
                                <TextBlock Text="{Binding Description}"
                                           Foreground="Gray"
                                           FontSize="12"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Add Button -->
        <Button Content="+ Add New Theme"
                Grid.Row="2"
                Style="{StaticResource PrimaryButton}"
                Margin="20,10,20,15"
                Click="BtnAdd_Click"/>
    </Grid>
</Window>