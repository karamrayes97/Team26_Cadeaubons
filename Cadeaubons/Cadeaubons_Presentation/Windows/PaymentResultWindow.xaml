<Window x:Class="Cadeaubons_Presentation.Windows.PaymentResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cadeaubons_Presentation.Windows"
        mc:Ignorable="d"
        Title="Betalingsresultaat" Height="500" Width="600"
        Background="White"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="400">

            <!-- Grote status-icoon -->
            <TextBlock x:Name="ResultIcon"
                       FontSize="72"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <!-- Titel -->
            <TextBlock x:Name="ResultTitle"
                       Style="{StaticResource WindowTitle}"
                       TextAlignment="Center"
                       Margin="0,0,0,15"/>

            <!-- Beschrijving -->
            <TextBlock x:Name="ResultMessage"
                       FontSize="14"
                       Foreground="Gray"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,0,0,30"/>

            <!-- Actie-knop -->
            <Button x:Name="BtnAction"
                    Style="{StaticResource PrimaryButton}"
                    Click="BtnAction_Click"/>

        </StackPanel>
    </Grid>
</Window>