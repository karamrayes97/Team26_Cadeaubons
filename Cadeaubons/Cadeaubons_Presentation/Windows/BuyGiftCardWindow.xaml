<Window x:Class="Cadeaubons_Presentation.Windows.BuyGiftCardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cadeaubons_Presentation.Windows"
        mc:Ignorable="d"
        Title="Cadeaubon kopen" Height="600" Width="800"
        Background="White"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0">
            <Button Content="← Terug"
                    Style="{StaticResource SecondaryButton}"
                    DockPanel.Dock="Right"
                    Width="100"
                    Click="BtnBack_Click"/>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🎁" FontSize="28" Margin="0,0,10,0"/>
                <TextBlock Text="Cadeaubon kopen"
                           Style="{StaticResource WindowTitle}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </DockPanel>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Width="350"
                        Margin="0,20">

                <!-- Bedrag -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="💶" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Bedrag (€) *" Style="{StaticResource FieldLabel}"/>
                </StackPanel>
                <TextBox x:Name="InitialAmountTextBox"
                         Style="{StaticResource RoundedTextBox}"
                         Margin="0,0,0,15"/>

                <!-- Thema -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="🎨" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Kies thema *" Style="{StaticResource FieldLabel}"/>
                </StackPanel>
                <ComboBox x:Name="ThemeComboBox"
          Style="{StaticResource RoundedComboBox}"
          Margin="0,0,0,15"
          SelectionChanged="ThemeComboBox_SelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding IconPath}"
                       FontSize="14"
                       Margin="0,0,6,0"
                       VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Name}"
                       VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- E-mailadres ontvanger -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="✉" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="E-mailadres ontvanger *" Style="{StaticResource FieldLabel}"/>
                </StackPanel>
                <TextBox x:Name="EmailTextBox"
                         Style="{StaticResource RoundedTextBox}"
                         Margin="0,0,0,8"/>

                <!-- Quick-fill: voor mezelf kopen -->
                <Button Content="Voor mezelf kopen"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,0,25"
                        Click="Button_Click"/>

                <!-- Kopen -->
                <Button x:Name="ButtonBuy"
                        Content="Kopen"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,0,10"
                        Click="ButtonBuy_Click"/>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Window>